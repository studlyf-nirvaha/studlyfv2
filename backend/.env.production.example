# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this to .env.production and fill in actual values
# NEVER commit .env.production to Git!

# ============ APPLICATION ============
ENVIRONMENT=production
DEBUG=False
SECRET_KEY=your-random-secret-key-here-min-32-chars
PORT=8000
LOG_LEVEL=info

# ============ MONGODB ============
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/production?retryWrites=true&w=majority
MONGO_DB_NAME=production

# ============ JWT & AUTHENTICATION ============
JWT_SECRET_KEY=your-jwt-secret-key-min-64-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=30

# ============ API CONFIGURATION ============
API_BASE_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ============ CORS (comma-separated) ============
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com,https://www.yourdomain.com
ALLOWED_HOSTS=api.yourdomain.com,yourdomain.com

# ============ HTTPS & SECURITY ============
HTTPS_ONLY=true
SECURE_COOKIES=true
HSTS_MAX_AGE=31536000

# ============ EMAIL (SendGrid) ============
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Your App Name

# ============ AI SERVICES (Groq) ============
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# ============ FILE UPLOADS ============
UPLOAD_DIR=/var/app/uploads
CERTIFICATE_DIR=/var/app/certificates
MAX_FILE_SIZE_MB=5
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx

# ============ RATE LIMITING ============
RATE_LIMIT_LOGIN=5/15min
RATE_LIMIT_SIGNUP=5/1hour
RATE_LIMIT_FORGOT_PASSWORD=3/1hour
RATE_LIMIT_EMAIL_VERIFICATION=10/1hour
RATE_LIMIT_GENERAL=100/1hour

# ============ REDIS (caching) ============
REDIS_URL=redis://username:password@redis-server:6379/0

# ============ MONITORING & LOGGING ============
SENTRY_DSN=your-sentry-dsn
LOG_TO_FILE=true
LOG_FILE_PATH=/var/log/app.json
LOG_ROTATION_SIZE=104857600
LOG_BACKUP_COUNT=10

# ============ DATABASE BACKUPS ============
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *

# ============ FEATURES ============
ENABLE_AUDIT_LOGGING=true
ENABLE_RATE_LIMITING=true
ENABLE_MONITORING=true
CREATE_INDEXES_ON_STARTUP=true
